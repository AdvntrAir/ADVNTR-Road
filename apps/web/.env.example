# Beehiiv integration — all values are safe to expose client-side (PUBLIC_ prefix).
# No Beehiiv API key is used or required for the static build.
#
# Discovered via Beehiiv MCP on 2026-07-03: the "ADVNTR Road" publication
# (pub_deb2e42d-316d-4040-aad7-01ca6aa0189e) exists but has no custom subscribe
# form configured yet. Until one exists, PUBLIC_BEEHIIV_PUBLICATION_URL is used
# as a link-out CTA. Set FORM_ACTION or EMBED_URL once Matt creates a form in
# Beehiiv to switch to an inline embed automatically — see SubscribeForm.astro.

PUBLIC_BEEHIIV_FORM_ACTION=
PUBLIC_BEEHIIV_EMBED_URL=
PUBLIC_BEEHIIV_PUBLICATION_URL=https://advntr-road.beehiiv.com
PUBLIC_BEEHIIV_RSS_URL=https://rss.beehiiv.com/feeds/CYY7cCTNl3.xml
