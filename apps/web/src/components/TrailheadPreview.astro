---
import SectionLabel from './SectionLabel.astro';
import { getLatestTrailhead } from '../lib/content-adapter';
const issue = await getLatestTrailhead();
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<section class="trailhead" id="trailhead">
  <div class="topo-field" aria-hidden="true">
    <img src="/images/brand/topo-lines.svg" alt="" />
  </div>
  <div class="container trailhead__inner">
    <SectionLabel label="The Trailhead" index={4} />
    <h2 data-reveal>Weekly national park intel for people planning real trips, not fantasy itineraries.</h2>
    <p class="trailhead__sub" data-reveal>
      Conditions, closures, access, and timing — read for the decisions it changes, not the headline.
    </p>

    {issue ? (
      <div class="trailhead__feed" data-reveal>
        <div class="trailhead__feed-header">
          <span class="trailhead__live"><span class="trailhead__live-dot" aria-hidden="true"></span>Latest Intel</span>
          <span class="trailhead__window">{fmt(issue.coverageWindowStart)} &ndash; {fmt(issue.coverageWindowEnd)}</span>
        </div>

        <h3 class="trailhead__headline">{issue.title}</h3>
        <p class="trailhead__summary">{issue.summary}</p>

        {issue.topStories.length > 0 && (
          <ul class="trailhead__feed-list">
            {issue.topStories.map((s) => (
              <li class="trailhead__feed-item">
                <span class="trailhead__feed-rank">{String(s.rank).padStart(2, '0')}</span>
                <div class="trailhead__feed-content">
                  <span class="trailhead__feed-region">{s.parkOrRegion}</span>
                  <span class="trailhead__feed-topic">{s.topic}</span>
                </div>
              </li>
            ))}
          </ul>
        )}

        {issue.affectedGuides.length > 0 && (
          <p class="trailhead__guides">Guides affected: {issue.affectedGuides.join(', ')}</p>
        )}

        <div class="trailhead__ctas">
          <a class="btn btn--primary" href={issue.href} target={issue.source === 'beehiiv-rss' ? '_blank' : undefined} rel={issue.source === 'beehiiv-rss' ? 'noopener noreferrer' : undefined}>
            Read the latest issue
          </a>
          <a class="btn btn--secondary" href="#subscribe">Subscribe for weekly intel</a>
        </div>
        {issue.source === 'local-fallback' && (
          <p class="trailhead__note">Showing local fallback content — live once the Beehiiv Intel Pack issue is published and classified.</p>
        )}
      </div>
    ) : (
      <p class="trailhead__note" data-reveal>The first Trailhead issue is in progress — check back soon.</p>
    )}
  </div>
</section>

<style>
  .trailhead {
    position: relative;
    overflow: hidden;
    background: var(--color-paynes-gray-dark);
    color: var(--text-on-dark);
    padding-block: var(--space-20);
  }
  .trailhead .eyebrow { color: var(--color-champagne); }
  .trailhead__inner { position: relative; z-index: 1; }
  .trailhead h2 { color: var(--text-on-dark); max-width: 26ch; font-size: clamp(1.5rem, 3.5vw, var(--text-3xl)); }
  .trailhead__sub { margin-top: var(--space-4); max-width: var(--measure-narrow); color: var(--text-on-dark-secondary); font-size: var(--text-lg); }

  .trailhead__feed {
    margin-top: var(--space-10);
    background: rgba(18, 45, 36, 0.35);
    border: 1px solid rgba(249, 228, 197, 0.2);
    border-top: var(--border-thick) solid var(--color-rust);
    padding: var(--space-8);
    max-width: 42rem;
  }
  .trailhead__feed-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .trailhead__live {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--text-on-dark);
  }
  .trailhead__live-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-rust);
    animation: trailhead-pulse 2s ease-in-out infinite;
  }
  @keyframes trailhead-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .trailhead__window {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-buff);
  }
  .trailhead__headline { margin-top: var(--space-4); color: var(--text-on-dark); font-size: clamp(1.375rem, 3vw, var(--text-2xl)); }
  .trailhead__summary { margin-top: var(--space-4); color: var(--text-on-dark-secondary); line-height: var(--leading-body); }

  .trailhead__feed-list {
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid rgba(249, 228, 197, 0.15);
  }
  .trailhead__feed-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-4);
    border-bottom: 1px solid rgba(249, 228, 197, 0.15);
  }
  .trailhead__feed-rank {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-rust);
  }
  .trailhead__feed-content { display: flex; flex-direction: column; gap: 2px; }
  .trailhead__feed-region { font-weight: var(--weight-semibold); color: var(--text-on-dark); }
  .trailhead__feed-topic { font-size: var(--text-sm); color: var(--text-on-dark-secondary); }

  .trailhead__guides { margin-top: var(--space-5); font-size: var(--text-xs); font-family: var(--font-mono); color: var(--text-on-dark-secondary); }
  .trailhead__ctas { margin-top: var(--space-7); display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .trailhead__ctas .btn--secondary { color: var(--text-on-dark); border-color: rgba(249,228,197,0.4); }
  .trailhead__note { margin-top: var(--space-5); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-on-dark-secondary); }
</style>
