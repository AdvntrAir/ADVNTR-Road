---
import { site } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="topo-field" aria-hidden="true">
    <img src="/images/brand/topo-lines.svg" alt="" />
  </div>
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <img src="/images/brand/advntr-road-logo-horizontal.png" alt={site.name} width="320" height="160" />
      <p class="site-footer__desc">{site.description}</p>
      <p class="site-footer__parent">A publication of {site.parentBrand} · ADVNTR Press (reserved)</p>
    </div>

    <nav class="site-footer__col" aria-label="Product">
      <p class="eyebrow">Product</p>
      <ul>
        {site.footerLinks.product.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <nav class="site-footer__col" aria-label="Legal">
      <p class="eyebrow">Legal</p>
      <ul>
        {site.footerLinks.legal.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="site-footer__col">
      <p class="eyebrow">Contact</p>
      <p><a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p>
    </div>
  </div>
  <div class="container site-footer__bottom">
    <p>&copy; {year} {site.name}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    background: var(--color-brunswick);
    color: var(--text-on-dark);
    padding-block: var(--space-16) var(--space-8);
    overflow: hidden;
  }
  .site-footer__inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-10);
    grid-template-columns: 1fr;
  }
  .site-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-5);
  }
  .site-footer__brand img {
    height: 80px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .site-footer__desc {
    max-width: 32ch;
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--text-on-dark-secondary);
    margin: 0;
  }
  .site-footer__parent {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-on-dark-secondary);
    margin: 0;
  }
  .site-footer__col ul {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .site-footer__col a {
    text-decoration: none;
    color: var(--text-on-dark-secondary);
    font-size: var(--text-sm);
  }
  .site-footer__col a:hover { color: var(--text-on-dark); }
  .site-footer .eyebrow { color: var(--color-buff); }
  .site-footer__bottom {
    position: relative;
    z-index: 1;
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(249, 228, 197, 0.15);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-on-dark-secondary);
  }

  @media (min-width: 720px) {
    .site-footer__inner { grid-template-columns: 1.4fr 1fr 1fr 1fr; }
  }
</style>
