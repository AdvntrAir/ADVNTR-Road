---
import SubscribeForm from './SubscribeForm.astro';
---
<section class="subscribe" id="subscribe">
  <div class="topo-field" aria-hidden="true">
    <img src="/images/brand/topo-lines.svg" alt="" />
  </div>
  <div class="container subscribe__inner">
    <p class="eyebrow" data-reveal>Join The Road List</p>
    <h2 data-reveal>Get the free guides, Field Notes, and weekly Trailhead intel.</h2>
    <p class="subscribe__sub" data-reveal>New releases and seasonal planning notes, delivered as they're ready. No spam, no generic travel sludge.</p>
    <div class="subscribe__form" data-reveal>
      <SubscribeForm />
    </div>
  </div>
</section>

<style>
  .subscribe {
    position: relative;
    overflow: hidden;
    background: var(--color-brunswick);
    color: var(--text-on-dark);
    padding-block: var(--space-20);
    text-align: center;
  }
  .subscribe__inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; }
  .subscribe .eyebrow { color: var(--color-buff); }
  .subscribe h2 { color: var(--text-on-dark); max-width: 24ch; font-size: clamp(1.5rem, 4vw, var(--text-3xl)); }
  .subscribe__sub { margin-top: var(--space-4); max-width: var(--measure-narrow); color: var(--text-on-dark-secondary); }
  .subscribe__form { margin-top: var(--space-8); width: 100%; max-width: 26rem; }
  .subscribe__form :global(.subscribe-form) { align-items: center; }
  .subscribe__form :global(.btn) { width: 100%; justify-content: center; }
</style>
