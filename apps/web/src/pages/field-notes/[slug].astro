---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('field-notes');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.excerpt}
  canonicalPath={`/field-notes/${entry.id}`}
  structuredData={[{
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: entry.data.title,
    description: entry.data.excerpt,
  }]}
>
  <section class="fn-masthead">
    <div class="topo-field" aria-hidden="true">
      <img src="/images/brand/topo-lines.svg" alt="" />
    </div>
    <div class="container fn-masthead__inner">
      <SectionLabel label="Field Notes" />
      <h1>{entry.data.title}</h1>
      {entry.data.publishedDate && <p class="fn-masthead__date">{fmt(entry.data.publishedDate)}</p>}
    </div>
  </section>

  <article class="container fn-article">
    {entry.data.status === 'placeholder' && (
      <p class="fn-article__flag">This piece is a launch placeholder — the full essay hasn't been written yet.</p>
    )}
    <div class="fn-article__body">
      <Content />
    </div>
    <p class="fn-article__back"><a href="/field-notes">&larr; All Field Notes</a></p>
  </article>
</BaseLayout>

<style>
  .fn-masthead {
    position: relative;
    overflow: hidden;
    background: var(--surface-kraft-paper);
    padding-block: var(--space-16) var(--space-12);
  }
  .fn-masthead .topo-field { opacity: 0.4; }
  .fn-masthead__inner { position: relative; z-index: 1; max-width: 42rem; }
  .fn-masthead h1 {
    margin-top: var(--space-3);
    font-size: clamp(2rem, 5vw, var(--text-5xl));
    color: var(--color-brunswick);
  }
  .fn-masthead__date {
    margin-top: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .fn-article { max-width: 42rem; padding-block: var(--space-16) var(--space-24); }
  .fn-article__flag {
    padding: var(--space-4);
    background: var(--surface-buff-subtle);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-accent);
  }
  .fn-article__body { margin-top: var(--space-8); color: var(--text-secondary); line-height: var(--leading-body); }
  .fn-article__back { margin-top: var(--space-12); font-family: var(--font-mono); font-size: var(--text-sm); }
</style>
