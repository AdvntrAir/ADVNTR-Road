---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('intel');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const stories = [...entry.data.topStories].sort((a, b) => a.storyRank - b.storyRank);
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.trailheadSummary}
  canonicalPath={`/intel/${entry.id}`}
>
  <article class="container intel-article">
    <p class="eyebrow">The Trailhead</p>
    <h1>{entry.data.title}</h1>
    <p class="intel-article__window">
      Coverage window: {fmt(entry.data.coverageWindowStart)} &ndash; {fmt(entry.data.coverageWindowEnd)}
    </p>
    <p class="intel-article__summary">{entry.data.trailheadSummary}</p>

    <h2>Top stories</h2>
    <ol class="intel-article__stories">
      {stories.map((s) => (
        <li>
          <strong>{s.parkOrRegion}</strong> — {s.topic}
          {s.explorerImpact && <p>{s.explorerImpact}</p>}
          {s.adventureRoadAngle && <p class="intel-article__angle">Angle: {s.adventureRoadAngle}</p>}
        </li>
      ))}
    </ol>

    {entry.data.affectedGuides.length > 0 && (
      <p class="intel-article__guides">Guides affected: {entry.data.affectedGuides.join(', ')}</p>
    )}

    <div class="intel-article__body"><Content /></div>
    <p class="intel-article__back"><a href="/intel">&larr; All Trailhead issues</a></p>
  </article>
</BaseLayout>

<style>
  .intel-article { max-width: 42rem; padding-block: var(--space-16) var(--space-24); }
  .intel-article h1 { margin-top: var(--space-3); font-size: var(--text-3xl); }
  .intel-article__window { margin-top: var(--space-4); font-family: var(--font-mono); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-label); color: var(--text-accent); }
  .intel-article__summary { margin-top: var(--space-5); color: var(--text-secondary); line-height: var(--leading-body); }
  .intel-article h2 { margin-top: var(--space-10); font-size: var(--text-xl); }
  .intel-article__stories { margin: var(--space-5) 0 0; padding-left: var(--space-5); display: flex; flex-direction: column; gap: var(--space-4); }
  .intel-article__stories p { margin-top: var(--space-1); color: var(--text-secondary); font-size: var(--text-sm); }
  .intel-article__angle { font-style: italic; }
  .intel-article__guides { margin-top: var(--space-6); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .intel-article__body { margin-top: var(--space-8); color: var(--text-secondary); line-height: var(--leading-body); }
  .intel-article__back { margin-top: var(--space-12); font-family: var(--font-mono); font-size: var(--text-sm); }
</style>
