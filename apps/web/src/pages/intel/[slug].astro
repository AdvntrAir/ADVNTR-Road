---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('intel');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const fmt = (d: Date) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const stories = [...entry.data.topStories].sort((a, b) => a.storyRank - b.storyRank);
---
<BaseLayout
  title={entry.data.title}
  description={entry.data.trailheadSummary}
  canonicalPath={`/intel/${entry.id}`}
>
  <section class="intel-masthead">
    <div class="topo-field" aria-hidden="true">
      <img src="/images/brand/topo-lines.svg" alt="" />
    </div>
    <div class="container intel-masthead__inner">
      <SectionLabel label="The Trailhead" />
      <h1>{entry.data.title}</h1>
      <p class="intel-masthead__window">
        Coverage window: {fmt(entry.data.coverageWindowStart)} &ndash; {fmt(entry.data.coverageWindowEnd)}
      </p>
    </div>
  </section>

  <article class="container intel-article">
    <p class="intel-article__summary">{entry.data.trailheadSummary}</p>

    <h2 class="intel-article__stories-label">Top stories</h2>
    <ul class="intel-article__feed">
      {stories.map((s) => (
        <li class="intel-article__feed-item">
          <span class="intel-article__feed-rank">{String(s.storyRank).padStart(2, '0')}</span>
          <div class="intel-article__feed-content">
            <p class="intel-article__feed-heading"><strong>{s.parkOrRegion}</strong> &mdash; {s.topic}</p>
            {s.explorerImpact && <p class="intel-article__feed-impact">{s.explorerImpact}</p>}
            {s.adventureRoadAngle && <p class="intel-article__feed-angle">Angle: {s.adventureRoadAngle}</p>}
          </div>
        </li>
      ))}
    </ul>

    {entry.data.affectedGuides.length > 0 && (
      <p class="intel-article__guides">Guides affected: {entry.data.affectedGuides.join(', ')}</p>
    )}

    <div class="intel-article__body"><Content /></div>
    <p class="intel-article__back"><a href="/intel">&larr; All Trailhead issues</a></p>
  </article>
</BaseLayout>

<style>
  .intel-masthead {
    position: relative;
    overflow: hidden;
    background: var(--color-paynes-gray-dark);
    color: var(--text-on-dark);
    padding-block: var(--space-16) var(--space-12);
  }
  .intel-masthead .eyebrow { color: var(--color-champagne); }
  .intel-masthead__inner { position: relative; z-index: 1; max-width: 42rem; }
  .intel-masthead h1 { margin-top: var(--space-3); font-size: clamp(1.75rem, 4.5vw, var(--text-4xl)); color: var(--text-on-dark); }
  .intel-masthead__window {
    margin-top: var(--space-4);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--color-buff);
  }

  .intel-article { max-width: 42rem; padding-block: var(--space-16) var(--space-24); }
  .intel-article__summary { color: var(--text-secondary); line-height: var(--leading-body); }
  .intel-article__stories-label {
    margin-top: var(--space-10);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .intel-article__feed { margin: var(--space-4) 0 0; padding: 0; list-style: none; border-top: var(--border-thin) solid var(--border-card); }
  .intel-article__feed-item {
    display: flex;
    gap: var(--space-4);
    padding-block: var(--space-5);
    border-bottom: var(--border-thin) solid var(--border-card);
  }
  .intel-article__feed-rank {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    color: var(--color-rust);
  }
  .intel-article__feed-heading { color: var(--text-primary); }
  .intel-article__feed-impact { margin-top: var(--space-2); color: var(--text-secondary); font-size: var(--text-sm); line-height: var(--leading-body); }
  .intel-article__feed-angle { margin-top: var(--space-2); color: var(--text-muted); font-size: var(--text-sm); font-style: italic; }
  .intel-article__guides { margin-top: var(--space-6); font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .intel-article__body { margin-top: var(--space-8); color: var(--text-secondary); line-height: var(--leading-body); }
  .intel-article__back { margin-top: var(--space-12); font-family: var(--font-mono); font-size: var(--text-sm); }
</style>
