---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath: string;
}
const { title, description, canonicalPath } = Astro.props;
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <article class="legal container">
    <p class="eyebrow">Legal</p>
    <h1>{title}</h1>
    <div class="legal__body">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .legal { max-width: 46rem; padding-block: var(--space-16) var(--space-24); }
  .legal h1 { margin-top: var(--space-3); font-size: var(--text-3xl); }
  .legal__body { margin-top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-5); }
  .legal__body :global(h2) { margin-top: var(--space-6); font-size: var(--text-xl); }
  .legal__body :global(p) { color: var(--text-secondary); line-height: var(--leading-body); }
  .legal__body :global(li) { color: var(--text-secondary); line-height: var(--leading-body); }
</style>
